# Web Backend
BACKEND_PORT=4019

# LLM Provider Settings: Base URL -> Model ID -> API Mode -> API Key

# OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_ID=gpt-5.6-terra
# OpenAI API 调用模式，仅支持以下两个值：
# responses：调用 /v1/responses，官方 OpenAI 与 GPT-5.6 推荐使用（默认）。
# chat_completions：调用 /v1/chat/completions，适用于只兼容传统接口的中转站或私有网关。
# 使用自定义 Base URL 时，请按服务商实际支持的接口选择，否则请求会返回 404/400。
OPENAI_API_MODE=responses
OPENAI_API_KEY=your_openai_key

# ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL_ID=claude-sonnet-5
ANTHROPIC_API_KEY=your_claude_key

# GOOGLE_BASE_URL=https://generativelanguage.googleapis.com
GOOGLE_MODEL_ID=gemini-3.5-flash
GOOGLE_API_KEY=your_gemini_key

# Search Engine Tokens
GITHUB_TOKEN=your_github_token
# SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_key
