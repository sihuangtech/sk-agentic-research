# LLM Provider Settings: Base URL -> Model ID -> API Mode -> API Key

# OPENAI_BASE_URL=https://your-openai-compatible-service/v1
OPENAI_MODEL_ID=gpt-4o-mini
OPENAI_API_MODE=chat_completions
OPENAI_API_KEY=your_openai_key

# ANTHROPIC_BASE_URL=https://your-anthropic-compatible-service
ANTHROPIC_MODEL_ID=claude-sonnet-4-5
ANTHROPIC_API_KEY=your_claude_key

# GOOGLE_BASE_URL=https://your-gemini-compatible-service
GOOGLE_MODEL_ID=gemini-2.5-flash
GOOGLE_API_KEY=your_gemini_key

# Search Engine Tokens
GITHUB_TOKEN=your_github_token
# SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_key
