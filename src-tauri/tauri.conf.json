{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "研序",
  "version": "0.2.0",
  "identifier": "cn.skstudio.papermill",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run desktop:before-dev",
    "beforeBuildCommand": "npm run desktop:prepare"
  },
  "app": {
    "windows": [
      {
        "title": "研序 · Agentic Research",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:*; img-src 'self' asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/papermill-backend"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-",
      "hardenedRuntime": false
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
